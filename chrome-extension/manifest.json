{
  "manifest_version": 3,
  "name": "VeilPaste",
  "version": "0.1.0",
  "description": "Small local utility for reducing AI-paste security risk.",
  "icons": {
    "16": "icons/veilpaste_16.png",
    "32": "icons/veilpaste_32.png",
    "48": "icons/veilpaste_48.png",
    "128": "icons/veilpaste_128.png"
  },
  "action": {
    "default_title": "VeilPaste",
    "default_icon": {
      "16": "icons/veilpaste_16.png",
      "32": "icons/veilpaste_32.png",
      "48": "icons/veilpaste_48.png",
      "128": "icons/veilpaste_128.png"
    }
  },
  "options_page": "help.html",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://www.perplexity.ai/*",
    "https://www.doubao.com/*",
    "https://chat.qwen.ai/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://www.perplexity.ai/*",
        "https://www.doubao.com/*",
        "https://chat.qwen.ai/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
