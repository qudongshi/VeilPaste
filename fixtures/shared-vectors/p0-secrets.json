[
  {
    "name": "api key headers",
    "input": "X-Api-Key: header-secret-value-12345\nX-Auth-Token: auth-token-value-67890\nApi-Key: api-key-value-abcdef\n",
    "expect_contains": [
      "X-Api-Key: [API_KEY_HEADER_1]",
      "X-Auth-Token: [API_KEY_HEADER_2]",
      "Api-Key: [API_KEY_HEADER_3]"
    ],
    "expect_not_contains": [
      "header-secret-value-12345",
      "auth-token-value-67890",
      "api-key-value-abcdef"
    ]
  },
  {
    "name": "basic authorization",
    "input": "Authorization: Basic dXNlcjpwYXNzd29yZA==\n",
    "expect_contains": [
      "Authorization: Basic [BASIC_AUTH_1]"
    ],
    "expect_not_contains": [
      "dXNlcjpwYXNzd29yZA=="
    ]
  },
  {
    "name": "cookie session header",
    "input": "Cookie: sessionid=prod_cookie_value; theme=dark\n",
    "expect_contains": [
      "Cookie: sessionid=[COOKIE_1]; theme=dark"
    ],
    "expect_not_contains": [
      "prod_cookie_value"
    ]
  },
  {
    "name": "quoted curl cookie session header",
    "input": "curl -H 'Cookie: sessionid=prod_cookie_value'\n",
    "expect_contains": [
      "curl -H 'Cookie: sessionid=[COOKIE_1]'"
    ],
    "expect_not_contains": [
      "prod_cookie_value"
    ]
  },
  {
    "name": "database and service urls",
    "input": "DATABASE_URL=postgres://app:dbpass@example.test/prod\nREDIS_URL=redis://:redispass@cache.example.test:6379/0\nMONGO_URI=mongodb://mongo:mongopass@mongo.example.test/app\nSENTRY_DSN=https://public:private@sentry.example.test/42\nWEBHOOK_URL=https://hooks.slack.com/services/T000/B000/secretwebhook\n",
    "expect_contains": [
      "DATABASE_URL=[DATABASE_URL_1]",
      "REDIS_URL=[REDIS_URL_1]",
      "MONGO_URI=[MONGO_URI_1]",
      "SENTRY_DSN=[SENTRY_DSN_1]",
      "WEBHOOK_URL=[WEBHOOK_URL_1]"
    ],
    "expect_not_contains": [
      "postgres://app:dbpass@example.test/prod",
      "redis://:redispass@cache.example.test:6379/0",
      "mongodb://mongo:mongopass@mongo.example.test/app",
      "https://public:private@sentry.example.test/42",
      "https://hooks.slack.com/services/T000/B000/secretwebhook"
    ]
  },
  {
    "name": "url userinfo",
    "input": "curl 'https://deploy:deploypass@example.test/api?debug=true'\n",
    "expect_contains": [
      "https://[URL_USERINFO_1]@example.test/api?debug=true"
    ],
    "expect_not_contains": [
      "deploy:deploypass"
    ]
  },
  {
    "name": "pem private key",
    "input": "PRIVATE_KEY=\"-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC\n-----END PRIVATE KEY-----\"\n",
    "expect_contains": [
      "PRIVATE_KEY=\"[PEM_PRIVATE_KEY_1]\""
    ],
    "expect_not_contains": [
      "MIIEvQIBADANBgkqhkiG9w0BAQEFAASC"
    ]
  },
  {
    "name": "package registry credentials",
    "input": "//registry.npmjs.org/:_authToken=npm_secret_token_1234567890\n[pypi]\nusername = __token__\npassword = pypi-secret-token-1234567890\n",
    "expect_contains": [
      "_authToken=[NPM_TOKEN_1]",
      "password = [PYPIRC_SECRET_1]"
    ],
    "expect_not_contains": [
      "npm_secret_token_1234567890",
      "pypi-secret-token-1234567890"
    ]
  },
  {
    "name": "docker auth json",
    "input": "{\"auths\":{\"registry.example.test\":{\"auth\":\"ZG9ja2VyOnNlY3JldA==\",\"email\":\"dev@example.test\"}}}\n",
    "expect_contains": [
      "\"auth\":\"[DOCKER_AUTH_1]\"",
      "\"email\":\"dev@example.test\""
    ],
    "expect_not_contains": [
      "ZG9ja2VyOnNlY3JldA=="
    ]
  },
  {
    "name": "chinese context with bearer token",
    "input": "帮我看一下这个接口为什么 401：Authorization: Bearer sk-live-abc1234567890\n",
    "expect_contains": [
      "帮我看一下这个接口为什么 401：Authorization: Bearer [BEARER_TOKEN_1]"
    ],
    "expect_not_contains": [
      "sk-live-abc1234567890"
    ]
  },
  {
    "name": "english context with database url",
    "input": "The local migration failed with DATABASE_URL=postgres://app:dbpass@example.test/prod in the env file.\n",
    "expect_contains": [
      "The local migration failed with DATABASE_URL=[DATABASE_URL_1] in the env file."
    ],
    "expect_not_contains": [
      "postgres://app:dbpass@example.test/prod"
    ]
  },
  {
    "name": "mixed markdown context with cookie",
    "input": "下面是复制出来的请求：\n```bash\ncurl -H 'Cookie: sessionid=prod_cookie_value; theme=dark'\n```\nPlease explain the failure.\n",
    "expect_contains": [
      "下面是复制出来的请求：",
      "curl -H 'Cookie: sessionid=[COOKIE_1]; theme=dark'",
      "Please explain the failure."
    ],
    "expect_not_contains": [
      "prod_cookie_value"
    ]
  },
  {
    "name": "fullwidth colon api key header",
    "input": "这个接口调用失败了，X-Api-Key：header-secret-value-12345\n",
    "expect_contains": [
      "这个接口调用失败了，X-Api-Key：[API_KEY_HEADER_1]"
    ],
    "expect_not_contains": [
      "header-secret-value-12345"
    ]
  }
]
